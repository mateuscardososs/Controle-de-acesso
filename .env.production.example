COMPOSE_PROJECT_NAME=access-control-prod

HTTP_PORT=80
# HTTPS_PORT=443
PUBLIC_BASE_URL=http://localhost

POSTGRES_DB=access_control
POSTGRES_USER=access_user
POSTGRES_PASSWORD=change-me-postgres

RABBITMQ_DEFAULT_USER=access_user
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq

JWT_SECRET=change-me-use-a-long-random-secret-with-at-least-32-chars
JWT_EXPIRATION_SECONDS=28800

APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
FRONTEND_PUBLIC_BASE_URL=http://localhost

# O browser usa o mesmo host do Nginx em producao.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=/ws

APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@empresa.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false

GUEST_INVITE_EXPIRATION_HOURS=72
GUEST_EXPIRATION_SCAN_DELAY_MS=300000
INTELBRAS_SYNC_MAX_ATTEMPTS=3
APP_INTELBRAS_MODE=fake
APP_INTELBRAS_DEFAULT_USERNAME=
APP_INTELBRAS_DEFAULT_PASSWORD=
APP_INTELBRAS_CONNECTION_TIMEOUT=3s
APP_INTELBRAS_READ_TIMEOUT=5s
APP_INTELBRAS_IDENTITY_STRATEGY=document
APP_INTELBRAS_EVENTS_POLLING_ENABLED=true
APP_INTELBRAS_EVENTS_POLLING_INTERVAL=5s
