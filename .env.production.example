COMPOSE_PROJECT_NAME=access-control-prod

HTTP_PORT=80
# HTTPS_PORT=443
PUBLIC_BASE_URL=https://cadastro.seudominio.com.br

PROMETHEUS_PORT=127.0.0.1:9090
PROMETHEUS_RETENTION_TIME=30d
GRAFANA_PORT=127.0.0.1:3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-use-a-strong-grafana-password

# Alertas Grafana por email (Gmail SMTP)
# Use App Password do Google — nunca a senha normal da conta.
# Passo a passo: https://myaccount.google.com/apppasswords
#   1. Acesse a conta Google -> Segurança -> Como fazer login no Google -> Verificacao em 2 etapas (ativar)
#   2. Apos ativar 2FA: Segurança -> Pesquisar "senhas de aplicativo"
#   3. Selecione "Outro (nome personalizado)", coloque "Grafana Consuma Catraca" e clique em Gerar
#   4. Copie a senha de 16 caracteres gerada (ex: abcd efgh ijkl mnop)
#   5. Cole sem espacos em GRAFANA_SMTP_PASSWORD abaixo
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.gmail.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
GRAFANA_SMTP_FROM_ADDRESS=
GRAFANA_SMTP_FROM_NAME=Consuma Catraca
GRAFANA_SMTP_STARTTLS_POLICY=MandatoryStartTLS
# Email que recebera os alertas (pode ser o mesmo ou diferente do remetente)
GRAFANA_ALERT_EMAIL_TO=

LOG_MAX_FILE_SIZE=50MB
LOG_MAX_HISTORY=90
LOG_TOTAL_SIZE_CAP=10GB

BACKUP_DIR=./backups
BACKUP_HOURLY_RETENTION_DAYS=14
BACKUP_DAILY_RETENTION_DAYS=90
BACKUP_MANUAL_RETENTION_DAYS=90
APP_ENVIRONMENT=production-local

POSTGRES_DB=access_control
POSTGRES_USER=access_user
POSTGRES_PASSWORD=change-me-postgres
# Opcional: use se preferir configurar o postgres-exporter por DSN unico.
# POSTGRES_EXPORTER_DATA_SOURCE_NAME=postgresql://access_user:change-me-postgres@postgres:5432/access_control?sslmode=disable

RABBITMQ_DEFAULT_USER=access_user
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq

JWT_SECRET=change-me-use-a-long-random-secret-with-at-least-32-chars
JWT_EXPIRATION_SECONDS=28800

APP_SEED_ADMIN_ENABLED=false
# Use apenas no primeiro boot se precisar criar um admin em producao.
# APP_SEED_ADMIN_EMAIL=admin@empresa.local
# APP_SEED_ADMIN_NAME=Administrador
# APP_SEED_ADMIN_PASSWORD=troque-por-uma-senha-forte-e-unica

APP_CORS_ALLOWED_ORIGINS=https://cadastro.seudominio.com.br,http://admin.local,http://localhost,http://127.0.0.1
APP_SIMULATOR_ENABLED=false
FRONTEND_PUBLIC_BASE_URL=https://cadastro.seudominio.com.br

# O browser usa o mesmo host do Nginx em producao.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=/ws
NEXT_PUBLIC_SIMULATOR_ENABLED=false

APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@empresa.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false

GUEST_INVITE_EXPIRATION_HOURS=72
GUEST_EXPIRATION_SCAN_DELAY_MS=300000
INTELBRAS_SYNC_MAX_ATTEMPTS=3
APP_INTELBRAS_MODE=fake
APP_INTELBRAS_DEFAULT_USERNAME=
APP_INTELBRAS_DEFAULT_PASSWORD=
APP_TIMEZONE=America/Recife
TZ=America/Recife
APP_LOUNGES=Front 1,Front 2,Front 3,Institucional 1,Institucional Vereador
APP_INTELBRAS_CONNECTION_TIMEOUT=3s
APP_INTELBRAS_READ_TIMEOUT=5s
INTELBRAS_CONNECT_TIMEOUT_MS=3000ms
INTELBRAS_READ_TIMEOUT_MS=5000ms
INTELBRAS_RETRY_ATTEMPTS=2
INTELBRAS_RETRY_BACKOFF_MS=300ms
INTELBRAS_HEALTH_INTERVAL_SECONDS=30s
INTELBRAS_IMPORT_INTERVAL_SECONDS=5s
INTELBRAS_DEDUP_WINDOW_SECONDS=300s
APP_INTELBRAS_IDENTITY_STRATEGY=document
APP_INTELBRAS_EVENTS_POLLING_ENABLED=true
APP_INTELBRAS_EVENTS_POLLING_INTERVAL=5s

# Intervalo mínimo entre liberações da mesma pessoa no mesmo dispositivo (segundos)
ACCESS_RELEASE_COOLDOWN_SECONDS=15
