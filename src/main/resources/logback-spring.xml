<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <customFields>{"application":"access-control-api"}</customFields>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>***</defaultMask>
                <path>password</path>
                <path>senha</path>
                <path>token</path>
                <path>authorization</path>
                <path>Authorization</path>
                <path>facePhoto</path>
                <path>photoData</path>
                <path>biometricData</path>
            </jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE:-logs/access-control-api.log}</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <customFields>{"application":"access-control-api"}</customFields>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>***</defaultMask>
                <path>password</path>
                <path>senha</path>
                <path>token</path>
                <path>authorization</path>
                <path>Authorization</path>
                <path>facePhoto</path>
                <path>photoData</path>
                <path>biometricData</path>
            </jsonGeneratorDecorator>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE:-logs/access-control-api}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE:-50MB}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY:-90}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP:-10GB}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
